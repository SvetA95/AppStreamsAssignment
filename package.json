{
  "name": "partner-e2e",
  "version": "1.0.0",
  "description": "E2E automation suite for Partner management workflow",
  "scripts": {
    "cy:open": "cypress open",
    "clean": "node -e \"['cypress/reports','cypress/screenshots','cypress/videos'].forEach(p=>require('fs').rmSync(p,{recursive:true,force:true}))\"",
    "cy:run:ui": "cypress run --spec 'cypress/e2e/**/*.cy.ts'",
    "cy:run:api": "cypress run --spec 'cypress/api/**/*.cy.ts' --config video=false",
    "cy:run": "npm run clean && npm run cy:run:ui && npm run cy:run:api",
    "cy:run:headed": "cypress run --headed",
    "cy:run:partners": "npm run clean && cypress run --spec 'cypress/e2e/partners/**/*.cy.ts'",
    "lint": "eslint cypress/**/*.ts cypress.config.ts",
    "lint:fix": "eslint cypress/**/*.ts cypress.config.ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cypress": "^13.13.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "eslint": "^8.57.0",
    "eslint-plugin-cypress": "^3.0.0",
    "mochawesome": "^7.1.4",
    "typescript": "^5.4.0"
  }
}
